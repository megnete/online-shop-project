<article class="product-item">
              <img src="<%= product.imageUrl %>" alt="<%= product.title %>" srcset="">
              <div class="product-item-content">
              <h2><%= product.title %></h2>
              <div class="product-item-actions">
                <a class="btn btn-alt" href="/admin/products/<%= product.id %>">View and Edit</a>
                <button class="btn btn-alt delete-product-button" data-productid="<%= product.id %>" data-csrf="<%= csrfToken %>">Delete</button>
              </div>
              </div>
            </article>