<%- include("../../shared/includes/head.ejs", { pageTitle: "Your cart" }) %>
<link rel="stylesheet" href="/styles/cart.css">
<script src="/scripts/cart-item-management.js"></script>
</head>
<body>
  <%- include("../../shared/includes/header.ejs") %>

    <main>
        <h1>Your Cart</h1>
   <ul id="cart-items">
    <% for (const cartItem of locals.cart.items) { %>
    <li>
    <%- include("./includes/cart-items.ejs", { cartItem: cartItem }) %>
    </li>
    <% } %>
</ul>
   <div id="cart-total">
    <p>Total: $<%= locals.cart.totalPrice.toFixed(2) %></span></p>
    <button class="btn">Buy Products</button>
   </div>
 </main>
<%- include("../../shared/includes/footer.ejs") %>
